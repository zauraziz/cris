# ===== Neon Postgres bağlantısı =====
# Neon panelindən və ya Vercel-in Neon inteqrasiyasından alınan bağlantı sətri.
# postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ===== ADDA korporativ e-poçt domeni =====
# Yalnız bu domenli e-poçtlar sistemə daxil ola bilər (vergüllə bir neçə domen olar).
NEXT_PUBLIC_EMAIL_DOMAIN=adda.edu.az

# ===== Admin paneli parolu (/admin) =====
# Bu parolu bilən şəxs idarəetmə panelinə (bütün tədqiqatçı məlumatları) daxil ola bilər.
ADMIN_PASSWORD=

# ===== (İstəyə bağlı) OpenAlex "polite pool" e-poçtu =====
OPENALEX_MAILTO=info@adda.edu.az

# ===== Cron təhlükəsizliyi (avtomatik yeniləmə) =====
# Bu dəyişəni təyin edin; Vercel cron çağırışını "Authorization: Bearer <CRON_SECRET>"
# başlığı ilə göndərəcək və endpoint yalnız bu başlıqla işləyəcək.
# Təsadüfi uzun bir sətir qoyun (məs. `openssl rand -hex 32` nəticəsi).
CRON_SECRET=

# ===== Pillələnmiş rollar (dekan / kafedra müdiri) =====
# Rektor/Administrator yuxarıdakı ADMIN_PASSWORD ilə daxil olur (istifadəçi adı boş).
# Dekan və kafedra müdirləri üçün hesabları aşağıdakı JSON massivində təyin edin.
# role: "dean" (fakültə) və ya "head" (kafedra). Parolları dəyişməyi unutmayın!
STAFF_ACCOUNTS=[{"user":"dekan.gs","pass":"DEYISIN_1","role":"dean","faculty":"Gəmi Sürücülüyü fakültəsi","name":"Gəmi Sürücülüyü — Dekan"},{"user":"dekan.gm","pass":"DEYISIN_2","role":"dean","faculty":"Gəmi Mexanikası və Elektromexanikası fakültəsi","name":"Gəmi Mexanikası — Dekan"},{"user":"kafedra.dn","pass":"DEYISIN_3","role":"head","faculty":"Gəmi Sürücülüyü fakültəsi","kafedra":"Dəniz naviqasiyası","name":"Dəniz naviqasiyası — Müdir"}]

# ===== (İstəyə bağlı) Sessiya imza açarı =====
# Təyin edilməzsə ADMIN_PASSWORD istifadə olunur. Təsadüfi uzun sətir tövsiyə olunur.
AUTH_SECRET=
